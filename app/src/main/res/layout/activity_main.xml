<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temi 智慧醫療助手"
                android:textSize="40sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btn_to_navigation"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                android:text="環境導覽"
                android:textSize="60sp"
                android:textStyle="bold"
                app:cornerRadius="30dp" />

            <Button
                android:id="@+id/btn_to_video"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                android:text="衛教宣導"
                android:textSize="60sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9800"
                app:cornerRadius="30dp" />

            <Button
                android:id="@+id/btn_to_ward_guide"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                android:text="病房導覽"
                android:textSize="60sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"
                app:cornerRadius="30dp" />

            <Button
                android:id="@+id/btn_to_broadcast"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                android:text="政策宣導"
                android:textSize="60sp"
                android:textStyle="bold"
                android:backgroundTint="#E91E63"
                app:cornerRadius="30dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/voice_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:background="#CC111111"
        android:padding="20dp"
        android:visibility="gone"
        android:elevation="12dp">

        <TextView
            android:id="@+id/tv_voice_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_voice_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="24sp" />
    </LinearLayout>

</FrameLayout>