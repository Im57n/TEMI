<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ========================================== -->
    <!-- 1. 選單畫面 (預設顯示) -->
    <!-- ========================================== -->
    <LinearLayout
        android:id="@+id/layout_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center">

        <!-- ✅ 標題字體放大 (56sp)，並加大 marginBottom (90dp) 讓它往上移 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="衛教影片播放中心"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="90dp"/>

        <!-- 4顆按鈕：改為 2x2 均分排列 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <Button
                android:id="@+id/btn_play_all"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="10dp"
                app:cornerRadius="20dp"
                android:text="病房須知"
                android:textSize="44sp" />

            <!-- ✅ 調換：手術需知移至右上角 -->
            <Button
                android:id="@+id/btn_video_3"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="10dp"
                app:cornerRadius="20dp"
                android:text="手術需知"
                android:textSize="44sp" />

            <Button
                android:id="@+id/btn_video_2"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="10dp"
                app:cornerRadius="20dp"
                android:text="化療常見 管路照護"
                android:textSize="44sp" />

            <!-- ✅ 調換：口腔清潔移至右下角 -->
            <Button
                android:id="@+id/btn_video_1"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="10dp"
                app:cornerRadius="20dp"
                android:text="口腔清潔"
                android:textSize="44sp" />
        </GridLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_back"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:text="返回"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:backgroundTint="#757575"
        app:cornerRadius="10dp" />

    <!-- ========================================== -->
    <!-- 2. 全螢幕播放畫面 (預設隱藏，點擊影片後才出現) -->
    <!-- ========================================== -->
    <FrameLayout
        android:id="@+id/layout_fullscreen_media"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone">

        <VideoView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <ImageView
            android:id="@+id/img_slideshow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />

        <!-- 獨立設定：暫停按鈕 (左下角) -->
        <Button
            android:id="@+id/btn_pause_resume"
            android:layout_width="160dp"
            android:layout_height="70dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="20dp"
            android:text="暫停播放"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            app:cornerRadius="35dp"
            android:elevation="10dp"/>

        <!-- 字幕顯示區塊 (半透明黑底白字，夾在按鈕之間) -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="200dp"
            android:layout_marginEnd="200dp"
            android:layout_marginBottom="20dp"
            android:minHeight="70dp"
            android:background="#99000000"
            android:padding="10dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:elevation="10dp"
            android:visibility="gone" />

        <!-- 獨立設定：退出影片按鈕 (右下角) -->
        <Button
            android:id="@+id/btn_exit_media"
            android:layout_width="160dp"
            android:layout_height="70dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:text="退出影片"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F44336"
            app:cornerRadius="35dp"
            android:elevation="10dp"/>

    </FrameLayout>

</FrameLayout>